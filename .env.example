APP_ENV=development
PRODUCTION_OFFLINE=false
ALLOW_RUNTIME_DOWNLOADS=false
BASE_URL=https://example.com

# Chromium no-egress hardening (Phase 5.1C). Default is ENABLED; set to false to launch the
# bundled Chromium with plain Playwright defaults only.
AWKIT_CHROMIUM_OFFLINE_HARDENING=true
# Optional extra Chromium switches (whitespace-separated), appended after the hardening args.
AWKIT_CHROMIUM_EXTRA_ARGS=

# Browser Resource Optimization (per-instance Chromium cost). All optional; default preserves today's
# behaviour exactly. Profile: maximum-compatibility | balanced (default) | low-resource | custom.
#   - balanced / maximum-compatibility: no request blocking, background throttling untouched, trace onFailure.
#   - low-resource: block image/media/font + analytics, block service workers, reduced motion, device-scale 1,
#     production artifacts (trace off), bounded 64MB disk cache, page cleanup. (Background throttling is NOT
#     used — the occlusion benchmark showed it gives no CPU benefit for automated instances; custom-only.)
# Workflow capabilities (screenshots→images, downloads, persistent-profile→service workers, popups→pages)
# automatically RELAX these so an aggressive profile never breaks a workflow.
AWKIT_BROWSER_RESOURCE_PROFILE=balanced
# Capability escape hatches — force a feature ON regardless of static detection (relax the profile):
# AWKIT_WORKFLOW_REQUIRES_IMAGES=false
# AWKIT_WORKFLOW_REQUIRES_MEDIA=false
# AWKIT_WORKFLOW_REQUIRES_SERVICE_WORKERS=false
# AWKIT_WORKFLOW_REQUIRES_WEBGL=false
# AWKIT_WORKFLOW_REQUIRES_GPU=false
# AWKIT_WORKFLOW_REQUIRES_ANIMATIONS=false
# AWKIT_WORKFLOW_REQUIRES_FULL_RESOLUTION=false

# Reporting/telemetry (UI-reports refactor, Phase 3). All optional.
# Chrome/host process-tree sampling for the consumption dashboard. Set to 0 to disable.
AWKIT_PROCESS_SAMPLING=1
# Bounded reporting retention: high-frequency samples kept this many hours (default 24).
AWKIT_REPORT_RETENTION_HOURS=24
# Reporting retention: most-recent terminal runs kept (default 5000). Interrupted/recoverable
# runs are always retained regardless of this cap.
AWKIT_REPORT_RETENTION_RUNS=5000

# Runtime Observability & Historical Analytics (migration v4). All optional; ON by default (rides the
# existing process sampler — disable everything with AWKIT_PROCESS_SAMPLING=0).
# Master switch for the incremental observability WORK (per-run environmental summaries, capacity/admission/
# lifecycle buckets, anomaly/regression detection). Default ON; set to 0 for A/B overhead benchmarking or
# troubleshooting. Leaves backpressure sampling + process-tree history untouched. NOT a production OFF default.
AWKIT_RUNTIME_OBSERVABILITY=1
# Capacity/admission/lifecycle time-bucket width in ms (default 30000; clamped 5000–300000).
AWKIT_OBSERVABILITY_BUCKET_MS=30000
# Retention for observability BUCKETS (aggregated, small) in days (default 14) — kept longer than raw samples.
AWKIT_OBSERVABILITY_BUCKET_RETENTION_DAYS=14
# Retention for anomaly/regression events in days (default 90; sparse + high value).
AWKIT_ANOMALY_RETENTION_DAYS=90

{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime --hook-json",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node scripts/ai-memory/check-memory.mjs",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  }
}
{
  "appId": "com.specterstudio.app",
  "productName": "SpecterStudio",
  "directories": {
    "output": "dist",
    "buildResources": "resources"
  },
  "files": [
    "out/**",
    "package.json",
    "node_modules/sql.js/dist/sql-wasm.js",
    "node_modules/sql.js/dist/sql-wasm.wasm"
  ],
  "asarUnpack": [
    "node_modules/playwright/**",
    "node_modules/playwright-core/**"
  ],
  "extraResources": [
    {
      "from": "resources",
      "to": "resources",
      "filter": [
        "**/*",
        "!icon-source.png",
        "!icon.png",
        "!test-fixtures/**",
        "!oracle-jdbc/**/*.env",
        "!oracle-jdbc/**/*.p12",
        "!oracle-jdbc/**/*.sso",
        "!oracle-jdbc/**/*.jks",
        "!oracle-jdbc/**/*.pem",
        "!oracle-jdbc/**/*.key",
        "!oracle-jdbc/**/tnsnames.ora",
        "!oracle-jdbc/**/sqlnet.ora"
      ]
    },
    {
      "from": "vendor",
      "to": "vendor",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "icon": "resources/icon.ico",
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "resources/icon.ico",
    "uninstallerIcon": "resources/icon.ico"
  }
}

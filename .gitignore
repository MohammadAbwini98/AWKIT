# === Electron / Vite / packaging ===
.vite/
electron-builder/
*.asar
# Generated timestamped electron-vite configs (source of truth is electron.vite.config.ts)
electron.vite.config.*.mjs

# === Bundled offline runtime (large binaries — Chromium, native modules, npm cache) ===
vendor/
resources/browsers/

# === Oracle JDBC bridge: compiled artifacts + the generated bridge bundle (staged at package time) ===
# The entire resources/oracle-jdbc/ bundle is generated by `npm run prepare:oracle-runtime` (bridge jar
# + manifest + checksums) and is never committed. Java runtimes and Oracle drivers are user-selected in
# Settings and never vendored here.
oracle-jdbc-bridge/target/
resources/oracle-jdbc/

# === Logo design exploration: superseded pre-rename families ===
# The SHIPPED mark's design source of truth is logos/specter-violet/, which IS tracked — do not
# add a blanket `logos/` rule here or new files under it would be silently ignored.
logos/awkit-violet/
logos/concepts/
logos/iterations/
logos/preview.html

# === Playwright ===
test-results/
playwright-report/
blob-report/
playwright/.cache/
traces/
videos/


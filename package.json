{
  "name": "playwright-flow-studio",
  "version": "0.1.0",
  "description": "Offline-capable Windows desktop studio for visual Playwright automation.",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc --noEmit && electron-vite build",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "mock-site": "node mock-site/server.mjs",
    "dev:mock-site": "node mock-site/server.mjs",
    "verify:runner": "tsx scripts/verify-runner.mts",
    "verify:mock-site": "node scripts/verify-mock-site.mjs",
    "verify:flow-designer": "node scripts/verify-flow-designer-gui.mjs",
    "verify:workflow-builder": "node scripts/verify-workflow-builder-gui.mjs",
    "verify:reports": "node scripts/verify-reports-gui.mjs",
    "verify:recorder": "tsx scripts/verify-recorder-locator.mts",
    "verify:waits": "tsx scripts/verify-waits.mts",
    "verify:concurrency": "tsx scripts/verify-concurrency.mts",
    "verify:locks": "tsx scripts/verify-locks.mts",
    "verify:browser-pool": "tsx scripts/verify-browser-pool.mts",
    "verify:watchdog": "tsx scripts/verify-watchdog.mts",
    "verify:artifacts": "tsx scripts/verify-artifacts.mts",
    "verify:runtime-status": "tsx scripts/verify-runtime-status.mts",
    "verify:durable-store": "tsx scripts/verify-durable-store.mts",
    "verify:telemetry": "tsx scripts/verify-telemetry.mts",
    "verify:durable-locks": "tsx scripts/verify-durable-locks.mts",
    "verify:cancellation": "tsx scripts/verify-cancellation.mts",
    "verify:safety-policy": "tsx scripts/verify-safety-policy.mts",
    "verify:dynamic-origin-claims": "tsx scripts/verify-dynamic-origin-claims.mts",
    "verify:resource-sampling": "tsx scripts/verify-resource-sampling.mts",
    "verify:startup-recovery": "tsx scripts/verify-startup-recovery.mts",
    "verify:recorder-draft": "tsx scripts/verify-recorder-draft.mts",
    "verify:recorder-flow": "tsx scripts/verify-recorder-flow.mts",
    "verify:protected-login": "tsx scripts/verify-protected-login.mts",
    "verify:protected-login-recorder": "tsx scripts/verify-protected-login-recorder.mts",
    "verify:data-editor": "tsx scripts/verify-data-editor.mts",
    "verify:instance-monitor": "tsx scripts/verify-instance-monitor.mts",
    "verify:popup": "tsx scripts/verify-popup.mts",
    "verify:popup-mock-site": "tsx scripts/verify-popup-mock-site.mts",
    "verify:packaged-runtime": "tsx scripts/verify-packaged-runtime.mts",
    "verify:packaged-walkthrough": "tsx scripts/verify-packaged-walkthrough.mts",
    "verify:chromium-hardening": "tsx scripts/verify-chromium-hardening.mts",
    "verify:soak:runtime": "tsx scripts/verify-soak-runtime.mts",
    "verify:stress:concurrency": "tsx scripts/verify-stress-concurrency.mts",
    "verify:stress:cancellation": "tsx scripts/verify-stress-cancellation.mts",
    "verify:stress:locks": "tsx scripts/verify-stress-locks.mts",
    "verify:stress:artifacts": "tsx scripts/verify-stress-artifacts.mts",
    "seed:mock-fixtures": "node scripts/seed-mock-fixtures.mjs",
    "icon:generate": "node scripts/generate-app-icon.mjs",
    "offline:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-offline-deps.ps1",
    "offline:manifest": "powershell -ExecutionPolicy Bypass -File scripts/generate-dependency-manifest.ps1",
    "prepare:offline": "powershell -ExecutionPolicy Bypass -File scripts/prepare-offline-deps.ps1 -InstallChromium",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "package:installer": "powershell -ExecutionPolicy Bypass -File scripts/package-per-user-installer.ps1",
    "package:nsis": "powershell -ExecutionPolicy Bypass -File scripts/package-per-user-installer.ps1",
    "package:offline": "npm run package:portable && npm run package:installer",
    "validate:offline": "powershell -ExecutionPolicy Bypass -File scripts/validate-offline-bundle.ps1",
    "ai:memory": "node scripts/ai-memory/check-memory.mjs",
    "ai:memory:check": "node scripts/ai-memory/check-memory.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "12.3.6",
    "lucide-react": "^0.468.0",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "1.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "1.4.11",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "2.1.0",
    "sharp": "0.32.6",
    "tsx": "4.22.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
